{
  "name": "rhea-enterprise-admin-plugin",
  "version": "0.0.1",
  "description": "Red Hat Enterprise Administrator — OpenShift console plugin embedding app admin UIs from labeled Services",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && NODE_ENV=production webpack --config webpack.config.cjs --progress",
    "build-dev": "npm run clean && webpack --config webpack.config.cjs --progress",
    "start": "RHEA_PREVIEW=1 webpack serve --progress --config webpack.config.cjs",
    "start:plugin": "webpack serve --progress --config webpack.config.cjs"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk": "4.20-latest",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.20-latest",
    "@patternfly/react-core": "^6.2.2",
    "@patternfly/react-icons": "^6.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^17.0.37",
    "@types/react-dom": "^17.0.11",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.3",
    "i18next": "^23.11.5",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-i18next": "^11.7.3",
    "react-router": "5.3.4",
    "react-router-dom": "5.3.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.100.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "consolePlugin": {
    "name": "rhea-enterprise-admin",
    "version": "0.0.1",
    "displayName": "Red Hat Enterprise Administrator",
    "description": "Unified admin shell: tabs per Route labeled admin=rhea (URL from host/TLS/path or rhea.redhat.com/console-url).",
    "exposedModules": {
      "EnterpriseAdminPage": "./components/EnterpriseAdminPage"
    },
    "dependencies": {
      "@console/pluginAPI": "^4.20.0"
    }
  }
}
